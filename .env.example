# Upsales API Configuration
# Copy this file to .env and fill in your credentials

# Primary authentication method - API token
UPSALES_TOKEN=your_api_token_here

# Fallback authentication (for sandbox environments that reset)
# Set to 'true' to enable automatic token refresh via username/password
UPSALES_ENABLE_FALLBACK_AUTH=false

# Credentials for fallback authentication
UPSALES_EMAIL=user@email.com
UPSALES_PASSWORD=your_password_here

# Optional: Custom base URL (defaults to https://power.upsales.com/api/v2)
# UPSALES_BASE_URL=https://power.upsales.com/api/v2

# Optional: Maximum concurrent requests (defaults to 50)
# UPSALES_MAX_CONCURRENT=50
